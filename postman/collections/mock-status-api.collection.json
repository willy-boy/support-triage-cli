        {
          "name": "billing-api — degraded",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('service = billing-api', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.service).to.eql('billing-api');",
                  "});",
                  "pm.test('status = degraded', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('degraded');",
                  "});",
                  "pm.test('lastIncident présent', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('lastIncident');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/status/billing-api",
              "host": ["{{base_url}}"],
              "path": ["status", "billing-api"]
            }
          },
          "response": []
